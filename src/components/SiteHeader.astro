---
interface Tab {
  slug: string;
  label: string;
}

interface Props {
  /** Which top-level page is active */
  activePath: 'home' | 'event' | 'about' | 'volunteer';
  /** Section pills (only present when activePath === 'event' for live switching) */
  tabs?: Tab[];
}

const { activePath, tabs = [] } = Astro.props;

const VOLUNTEER_SLUG = 'media-showcase-2026-volunteer';

const sectionLabels = [
  { slug: 'media-showcase-2026', label: 'Overview', icon: '🎭' },
  { slug: 'media-showcase-2026-attend', label: 'Tickets', icon: '🎟️' },
  { slug: 'media-showcase-2026-schedule', label: 'Program', icon: '📋' },
  { slug: 'media-showcase-2026-performer-info', label: 'Performer Info', icon: '🎸' },
  { slug: 'media-showcase-2026-food-venue', label: 'Food & Venue', icon: '📍' },
];

// On /event, use the dynamically-fetched tabs (in-order, excluding Volunteer
// since Volunteer is a top-level nav item now, not a section). Otherwise use
// the static label list above.
const sections = activePath === 'event' && tabs.length > 0
  ? tabs
      .filter((t) => t.slug !== VOLUNTEER_SLUG)
      .map((t, i) => ({
        slug: t.slug,
        label: t.label,
        icon: sectionLabels.find((s) => s.label === t.label)?.icon ?? '📄',
        index: i,
      }))
  : sectionLabels.map((s, i) => ({ ...s, index: i }));

// Default-active styling for the section pills:
// - On /event: first pill (Overview) is active until JS reads URL hash + switches.
// - On / or /about: no section pill is active (Submit/About pill is active instead).
const eventDefaultActiveIdx = activePath === 'event' ? 0 : -1;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background/85 backdrop-blur-md border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-1 h-14 overflow-x-auto scrollbar-hide">
      {/* Logo — only thing on the left */}
      <a href="/" class="flex items-center gap-2 font-bold text-sm shrink-0 mr-3">
        <span class="gradient-text">SWC</span>
        <span class="text-foreground hidden sm:inline">Media Showcase</span>
      </a>

      {/* Spacer pushes everything to the right */}
      <div class="flex-1"></div>

      {/* Section pills (Overview / Tickets / Schedule / Performer Info / Food & Venue) */}
      {sections.map((s) => {
        const isActive = activePath === 'event' && s.index === eventDefaultActiveIdx;
        const href = activePath === 'event' ? `#${s.slug}` : `/event#${s.slug}`;
        return (
          <a
            href={href}
            data-tab={activePath === 'event' ? s.index : undefined}
            data-section-pill
            class:list={[
              'flex items-center gap-1.5 px-3 py-2 text-base font-medium transition-colors whitespace-nowrap shrink-0 border-b-2 -mb-px',
              isActive
                ? 'text-primary border-primary'
                : 'text-muted-foreground border-transparent hover:text-foreground',
            ]}
          >
            <span>{s.icon}</span>
            <span>{s.label}</span>
          </a>
        );
      })}

      {/* About pill — right before Submit + Volunteer */}
      <a
        href="/about"
        class:list={[
          'flex items-center gap-1.5 px-3 py-2 text-base font-medium transition-colors whitespace-nowrap shrink-0 border-b-2 -mb-px',
          activePath === 'about'
            ? 'text-primary border-primary'
            : 'text-muted-foreground border-transparent hover:text-foreground',
        ]}
      >
        <span>ℹ️</span>
        <span>About</span>
      </a>

      {/* Submit pill — next-to-last */}
      <a
        href="/"
        class:list={[
          'flex items-center gap-1.5 px-3 py-2 text-base font-medium transition-colors whitespace-nowrap shrink-0 border-b-2 -mb-px',
          activePath === 'home'
            ? 'text-primary border-primary'
            : 'text-muted-foreground border-transparent hover:text-foreground',
        ]}
      >
        <span>📝</span>
        <span>Submit</span>
      </a>

      {/* Volunteer pill — last */}
      <a
        href="/volunteer"
        class:list={[
          'flex items-center gap-1.5 px-3 py-2 text-base font-medium transition-colors whitespace-nowrap shrink-0 border-b-2 -mb-px',
          activePath === 'volunteer'
            ? 'text-primary border-primary'
            : 'text-muted-foreground border-transparent hover:text-foreground',
        ]}
      >
        <span>🤝</span>
        <span>Volunteer</span>
      </a>
    </div>
  </div>
</header>
