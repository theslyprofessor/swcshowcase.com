---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubmissionForm from "@/components/react/SubmissionForm";
---

<BaseLayout
  title="Submit — Media Showcase 2026"
  description="Submit your work for the Media Showcase 2026 at Southwestern College."
>
  {/* Header */}
  <header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 font-bold text-sm">
          <span class="gradient-text">SWC</span>
          <span class="text-foreground">Media Showcase</span>
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/" class="text-muted-foreground hover:text-foreground transition-colors">
            Event Info
          </a>
          <a
            href="https://southwesternrecording.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground transition-colors hidden sm:inline"
          >
            southwesternrecording.com
          </a>
        </div>
      </div>
    </nav>
  </header>

  <main class="pt-24 pb-16 bg-background min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Header */}
      <div class="text-center mb-12">
        <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-3">
          Southwestern College &middot; RA&T + FTMA
        </p>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">
          <span class="gradient-text">Submit</span>
          <span class="text-foreground"> Your Work</span>
        </h1>
        <p class="text-muted-foreground max-w-xl mx-auto">
          Express your interest in presenting at the Media Showcase on
          Wednesday, May 13, 2026. Space may be limited — submit early
          to increase your chances.
        </p>
      </div>

      {/* Form */}
      <SubmissionForm client:load eventSlug="media-showcase-2026" />
    </div>
  </main>

  {/* Footer */}
  <footer class="border-t border-border py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-muted-foreground">
      <span>&copy; {new Date().getFullYear()} Southwestern College</span>
      <span class="mx-2">&middot;</span>
      <a
        href="https://southwesternrecording.com"
        class="hover:text-foreground transition-colors"
      >
        Center for Recording Arts & Technology
      </a>
    </div>
  </footer>
</BaseLayout>
