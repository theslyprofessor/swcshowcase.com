---
import BaseLayout from "@/layouts/BaseLayout.astro";
import VolunteerForm from "@/components/react/VolunteerForm";
import SiteHeader from "@/components/SiteHeader.astro";
---

<BaseLayout
  title="Volunteer — Media Showcase 2026"
  description="Sign up to volunteer at the Media Showcase 2026 at Southwestern College."
>
  <SiteHeader activePath="volunteer" />

  <main class="pt-24 pb-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 max-w-2xl mx-auto">
        <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-3">
          Wednesday, May 13, 2026 &middot; SWCPAC
        </p>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">
          <span class="gradient-text">Volunteer</span>
          <span class="text-foreground"> at the Showcase</span>
        </h1>
        <p class="text-muted-foreground">
          We need help across the whole day — load-in at noon, doors at 5:30 PM,
          strike around 10 PM. Tell us when you're free and what you'd like to
          do, and we'll match you to a shift.
        </p>
      </div>

      <VolunteerForm client:load eventSlug="media-showcase-2026" />

      {/* Cross-promo: SWCPAC ushering for other PAC events */}
      <aside class="max-w-2xl mx-auto mt-12 bg-secondary/30 border border-border rounded-xl p-6">
        <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-2">
          Also at SWCPAC
        </p>
        <h2 class="text-xl font-bold mb-3">Usher for other Performing Arts Center events</h2>
        <p class="text-sm text-muted-foreground mb-4 leading-relaxed">
          The PAC needs ushers for every show on the calendar — Jazz Café, Drama Festival,
          and more. Ushers welcome guests, scan tickets, and guide audiences during
          performances. Hands-on event experience, resume material, and (at your
          instructor's discretion) potential extra credit or service hours.
        </p>
        <a
          href="https://www.signupgenius.com/go/10C0449AEAF2FA0F4C70-62076924-spring#/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary/10 text-primary border border-primary/30 font-semibold px-5 py-2.5 rounded-lg hover:bg-primary/20 transition-colors text-sm"
        >
          Sign up via Lizette's SignUpGenius
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <p class="text-xs text-muted-foreground mt-3">
          (Separate from this form — that link goes to the PAC's general usher schedule.)
        </p>
      </aside>
    </div>
  </main>

  <footer class="border-t border-border py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-muted-foreground">
      <span>&copy; {new Date().getFullYear()} Southwestern College</span>
      <span class="mx-2">&middot;</span>
      <a href="/about" class="hover:text-foreground transition-colors">About</a>
    </div>
  </footer>
</BaseLayout>
