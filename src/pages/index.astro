---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EventTabs from "@/components/react/EventTabs";
import { fetchEventTabs } from "@/lib/convex";

// ---------------------------------------------------------------------------
// Build-time fetch from Convex (convex-content module)
// ---------------------------------------------------------------------------
const FOLDER_PATH = "Academic Resources/Events/Media Showcase 2026";

let tabs: Awaited<ReturnType<typeof fetchEventTabs>> = [];
let fetchError = "";

try {
  tabs = await fetchEventTabs(FOLDER_PATH);
} catch (e) {
  fetchError = e instanceof Error ? e.message : "Failed to load event content";
  console.error("Convex fetch error:", fetchError);
}
---

<BaseLayout>
  {/* Header — nav with tab shortcuts for mobile */}
  <header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 font-bold text-sm">
          <span class="gradient-text">SWC</span>
          <span class="text-foreground">Media Showcase</span>
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="#tabs" class="text-muted-foreground hover:text-foreground transition-colors" data-tab="0">Overview</a>
          <a href="#tabs" class="text-muted-foreground hover:text-foreground transition-colors" data-tab="3">Performer Info</a>
          <a href="#tabs" class="text-muted-foreground hover:text-foreground transition-colors" data-tab="4">Volunteer</a>
          <a
            href="https://southwesternrecording.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground transition-colors hidden sm:inline"
          >
            southwesternrecording.com
          </a>
        </div>
      </div>
    </nav>
  </header>

  <main>
    {/* Hero */}
    <section class="gradient-hero pt-24 pb-16 sm:pt-32 sm:pb-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-4">
            Southwestern College &middot; Center for Recording Arts & Technology
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
            <span class="gradient-text">Media</span>
            <span class="text-foreground"> Showcase</span>
            <span class="text-muted-foreground font-light"> 2026</span>
          </h1>

          <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-muted-foreground mb-8">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              <span>Wednesday, May 13, 2026</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <span>SWCPAC, Chula Vista</span>
            </div>
          </div>

          <p class="text-lg text-muted-foreground leading-relaxed max-w-2xl">
            An evening celebrating student work in audio engineering, music production,
            electronic composition, and media arts.
          </p>
        </div>
      </div>
    </section>

    {/* Tabbed Content */}
    <section id="tabs" class="bg-background scroll-mt-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {fetchError ? (
          <div class="bg-card rounded-xl p-8 border border-border text-center">
            <p class="text-muted-foreground">{fetchError}</p>
            <p class="text-sm text-muted-foreground mt-2">
              Event details are being loaded. Please check back soon.
            </p>
          </div>
        ) : (
          <EventTabs client:load tabs={tabs} />
        )}
      </div>
    </section>
  </main>

  {/* Footer */}
  <footer class="border-t border-border py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-muted-foreground">
        <div class="flex items-center gap-2">
          <span>&copy; {new Date().getFullYear()} Southwestern College</span>
          <span>&middot;</span>
          <a
            href="https://southwesternrecording.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors"
          >
            Center for Recording Arts & Technology
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://instagram.com/swc.recordingarts"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors"
          >
            @swc.recordingarts
          </a>
          <span>&middot;</span>
          <span>900 Otay Lakes Road, Chula Vista, CA 91910</span>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
