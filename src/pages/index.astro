---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubmissionForm from "@/components/react/SubmissionForm";
import SiteHeader from "@/components/SiteHeader.astro";
---

<BaseLayout>
  <SiteHeader activePath="home" />

  <main class="pt-24 pb-16 bg-background min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto mb-10 text-center">
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">
          <span class="gradient-text">Submit</span>
          <span class="text-foreground"> Your Work</span>
        </h1>
        <p class="text-muted-foreground mb-2">
          Tell us what you'd like to present at the Media Showcase 2026. Space is limited —
          earlier submissions get priority slot consideration.
        </p>
        <p class="text-sm text-amber-300">
          Submission deadline: <span class="font-semibold">Sunday, May 10 · 11:59 PM</span>
        </p>
        <p class="text-xs text-muted-foreground mt-3">
          Need event details? <a href="/event" class="text-primary hover:underline">See Overview →</a>
        </p>
      </div>

      <SubmissionForm client:load eventSlug="media-showcase-2026" />
    </div>
  </main>

  {/* Footer */}
  <footer class="border-t border-border py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-muted-foreground">
        <div class="flex items-center gap-2">
          <span>&copy; {new Date().getFullYear()} Southwestern College</span>
          <span>&middot;</span>
          <a href="/about" class="hover:text-foreground transition-colors">About</a>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://southwesternrecording.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors"
          >
            southwesternrecording.com
          </a>
          <span>&middot;</span>
          <a
            href="https://instagram.com/swc.recordingarts"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-foreground transition-colors"
          >
            @swc.recordingarts
          </a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
